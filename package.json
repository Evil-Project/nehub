{
  "name": "nehub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run build && wrangler dev",
    "dev:client": "vite --host 0.0.0.0",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply nehub-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply nehub-db --remote"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  }
}
